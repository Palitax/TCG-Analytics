{
  "manifest_version": 3,
  "name": "TCG Card Tracker",
  "version": "1.0.0",
  "description": "Monitore Kartenpreise mit automatischer Synchronisierung und elegantem Glasmorphismus-Overlay.",
  "key": "",
  "permissions": [
    "storage",
    "identity",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://*.cardmarket.com/*",
    "https://pjorjwwhiinaaebxvhhi.supabase.co/*",
    "https://*.amazonaws.com/*",
    "https://*.cloudfront.net/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.cardmarket.com/*/Products/Singles/*"
      ],
      "js": [
        "scripts/content.js"
      ],
      "css": [
        "scripts/content.css"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "http://localhost/*",
        "https://tcg-analytics-chi.vercel.app/*"
      ],
      "js": [
        "scripts/webapp-helper.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
